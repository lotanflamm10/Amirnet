NEXT_PUBLIC_APP_NAME=AMIRNET Trainer
PAYMENTS_MODE=mock
NEXT_PUBLIC_PAYMENTS_MODE=mock
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Friends-testing multi-user auth (temporary) ───────────────────────
# All are OPTIONAL. Defaults are baked into src/lib/auth/users.ts.
# Set these on Vercel to override seed passwords without committing them.
#
# Built-in users (cannot be removed without code changes):
#   admin / tsnhi5326    (id: admin,  role: admin)
#   גילי   / גילי7369!     (id: gili,   role: student)
#
# AUTH_SECRET must be set to a strong random value in production — it's
# the HMAC signing key for the session cookie and the per-user password
# override cookie. If unset, a dev-only default is used (NOT secure).
AUTH_SECRET=replace-with-a-32-byte-random-string-on-vercel

# Override seed passwords per user (optional — only set if you want to
# change the password baseline without editing source code):
ADMIN_SEED_PASSWORD=tsnhi5326
GILI_SEED_PASSWORD=גילי7369!

# Optional: set to "1" to re-enable the /admin route. Leave unset/0
# to keep /admin returning 404 (default behavior).
ADMIN_ENABLED=0
