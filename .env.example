NEXT_PUBLIC_APP_NAME=AMIRNET Trainer
PAYMENTS_MODE=mock
NEXT_PUBLIC_PAYMENTS_MODE=mock
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Friends-testing access gate (temporary) ───────────────────────────
# Both are OPTIONAL. If unset, the gate falls back to admin / admin.
# On Vercel: Project → Settings → Environment Variables → add for
# Production (and optionally Preview), then redeploy.
# Do NOT commit a real .env file to git.
GATE_USERNAME=admin
GATE_PASSWORD=admin

# Optional: set to "1" to re-enable the /admin route. Leave unset/0
# to keep /admin returning 404 (default behavior).
ADMIN_ENABLED=0
